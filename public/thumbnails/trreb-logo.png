 var(--wp--preset--font-size--xx-large) !important;}.has-dm-sans-font-family{font-family: var(--wp--preset--font-family--dm-sans) !important;}.has-ibm-plex-mono-font-family{font-family: var(--wp--preset--font-family--ibm-plex-mono) !important;}.has-inter-font-family{font-family: var(--wp--preset--font-family--inter) !important;}.has-system-font-font-family{font-family: var(--wp--preset--font-family--system-font) !important;}.has-source-serif-pro-font-family{font-family: var(--wp--preset--font-family--source-serif-pro) !important;}
html {
  scroll-behavior: smooth;
}

body {
	--wp--preset--font-family--inter: "Effra", sans-serif;
}

a {
	transition: all 0.25s ease-in-out;
}

a:hover {
	color: #006BD3;
}

.menu-image-link {
	transition: all 0.25s ease-in-out;
}

.menu-image-link:hover {
	filter: hue-rotate(180deg);
}

.text-grey {
	color:#5C5E61;
}

.text-azure {
	color: #016BD3;
}

.text-orange {
	color: #F3A801;
}

.wp-site-blocks {
    padding-bottom: 0;
}

.wp-block-button, .wp-element-button {
	transition: all 0.25s ease-in-out;
}

.wp-element-button:hover {
	filter: invert(1);
}

.wp-block-post-title a:where(:not(.wp-element-button)):hover {
    text-decoration: none;
}

.featured_post .wp-block-post-title {
	font-weight: bold;
	padding-top: 1rem;
	border-top: 1px solid #cccccc;
}

.featured_post .wp-block-post-title a{
	text-decoration: none;
}

.cut_corners img{
	clip-path: polygon(55% 0, 100% 0, 100% 75%, 45% 100%, 0 100%, 0 25%);
}


.wp-block-latest-posts__post-title {
	font-size: 1.4em;
	font-weight: bold;
	text-decoration: none;
	 line-height: 1.4em;
	 margin: 1em 0;
	 display: block;
	border-top: 1px solid #77787A;
    padding-top: 1rem;
	margin-bottom: 0px;
}

@media (min-width:1192px) {
	.wp-block-latest-posts__post-title {
	min-height: 120px;
}
}

.hp-market_news.wp-block-latest-posts.columns-3 li:first-child {
    display: none;
}

@media (min-width: 600px) {
.hp-market_news.wp-block-latest-posts.columns-3 li:first-child {
    display: none;
}
	
	.hp-market_news.wp-block-latest-posts.columns-3 li:nth-child(4n) {
   transform: translateX(1.5rem);
}
}

.wp-block-details {
		padding-top: 1.4rem;
    border-top: 1px solid #77787A;
}

.wp-block-details summary{
	font-size: 1.5rem;
	font-weight:bold;
}

.featured1_plus5 .wp-block-post-title {
	display: block;
	border-top: 1px solid #77787A;
  padding-top: 1rem;
}


.wp-block-latest-posts li {
	display: flex;
  flex-direction: column;
}

.wp-block-latest-posts__featured-image {
	order: 3;
  padding-top: 3rem;
}


.hp-mw_minute .wp-block-media-text .wp-block-media-text__content {
    padding-left: 0px;
}



details>summary {
 
  list-style: none;
}
summary::-webkit-details-marker {
  display: none
}

summary::after {
    float: right;
    content: '˃';
    font-weight: normal;
    transform: scale(2);
    position: relative;
    top: 6px;
    right: 20px;
}

details[open] summary:after {
  content: '⌄';
	top: -16px;
}

details[open] summary ~ * {
  animation: sweep .5s ease-in-out;
}


@keyframes sweep {
  0%    {opacity: 0;}
  100%  {opacity: 1;}
}

.entry-content a[href][href*="pdf"]:after {
    content: '\f1c1';
    font-family: FontAwesome;
    font-weight: normal;
    font-style: normal;
    font-size: 0.7em;
    color: #272C37;
    margin: 0px 5px;
    text-decoration: none;
}

.entry-content a[target="_blank"]:after {
    content: '\f08e';
    font-family: FontAwesome;
    font-weight: normal;
    font-style: normal;
    font-size: 0.7em;
    color: #272C37;
    margin: 0px 5px;
    text-decoration: none;
}

footer .wp-block-social-link {
    color: white !important;
}

.wp-block-social-link:hover {
    transform: scale(1.2);
}


footer a {
	color: white;
	text-decoration: none;
	transition: all 0.25s ease-in-out;
}

footer a:hover {
	color: #006BD3;
}.hide {
  display:none;
}

/* Modal */

.modal {
  opacity: 0;
  visibility: hidden;
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  text-align: left;
  background: rgba(0,107,211, .8);
  transition: opacity .25s ease;
}

.modal__bg {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  cursor: pointer;
}

.modal-state {
  display: none;
}

.modal-state:checked + .modal {
  opacity: 1;
  visibility: visible;
}

.modal-state:checked + .modal .modal__inner {
  top: 0;
}

.modal__inner {
  transition: top .25s ease;
  position: absolute;
  top: -20%;
  right: 0;
  bottom: 0;
  left: 0;
  width: 50%;
  margin: auto;
  overflow: auto;
  background: #fff;
  padding: 2em;
  height: 70%;
  box-shadow: 0 0 50px rgba(0,0,0,0.5);
}

.modal__close {
  position: absolute;
  right: 3em;
  top: 2em;
  width: 3em;
  height: 1.1em;
  cursor: pointer;
  color:#aaaaaa;
}

.modal__close:after,
.modal__close:before {
  content: '';
  position: absolute;
  width: 2px;
  height: 1.5em;
  background: #ccc;
  display: block;
  transform: rotate(45deg);
  left: 4rem;
  margin: -3px 0 0 -1px;
  top: 4px;
}

.modal__close:hover:after,
.modal__close:hover:before {
  background: #aaa;
}

.modal__close:before {
  transform: rotate(-45deg);
}

@media screen and (max-width: 768px) {
	
  .modal__inner {
    width: 90%;
    height: 90%;
    box-sizing: border-box;
  }
}

.modal-link h3 {
  margin: 24px 0;
}

.modal-label {
 cursor: pointer;
}

.dinfo {
  display:flex;
  flex-direction: column;
  color:#272C37;
}

.drow {
  display:flex;
  flex-wrap: wrap;
}

.dimage {
  min-width: 300px;
  max-width: 320px;
  margin-right: 2rem;
}

.dimage img {
  width:100%;
  border-radius:6px;
}

.dcreds {
  align-self: end;
  margin-top: 2rem;
}

.dname {
  font-size:2.5em;
  font-weight:bold;
  margin: 0;
}

.drole {
  margin: 0.5em 0;
}

.dcompany {
  font-weight: bold;
  margin: 0.5em 0;
}

.dbio {
  margin-top: 3rem;
  margin-bottom: 1rem;
}

.trrebwire-menu {
  padding-top:0.5rem !important;
  padding-bottom:0.5rem !important;
}

.trrebwire-menu summary {
  font-size:2.5rem;
}

.trrebwire-menu summary::before {
    float: right;
    content: '\2261';
    font-weight: normal;
    transform: scale(1);
    position: relative;
    top: -3px;
    right: 20px;
}

.trrebwire-menu summary::after {
    float: right;
    content: 'Topics';
    font-weight: normal;
    transform: scale(0.5);
    position: relative;
    top: 0px;
    right: 0px;
}

@media screen and (max-width: 457px) {
	
  .trrebwire-menu summary::after {
    display: none;
  }
  
  .trrebwire-menu summary {
    font-size: 2rem;
}

} 

.trrebwire-menu[open] summary::before{
  content: '\2715';
  font-weight: normal;
  transform: scale(0.5);
  position: relative;
  top: 0px;
  right: 20px;
}

.trrebwire-menu[open] summary::after{
  content: 'Topics';
  font-weight: normal;
  transform: scale(0.5);
  position: relative;
  top: 0px;
  right: -7px;
}

.trrebwire-menu_details {
  border-top: 1px solid #ffffff;
  padding:2.5rem 0;
}

.trrebwire-menu_pill {
    border: 2px solid #ffffff;
    border-radius: 20px;
    padding: 0.4em 1em;
    margin-right: 1em;
    font-weight: normal;
    transition: all 0.25s ease-in-out;
}

.trrebwire-menu_pill:hover {
  background-color:dodgerblue;
}

.single-previous_title, .single-next_title:not(:empty) {
  border-top: 1px solid #777777;
padding-top:1rem;
  font-weight:bold;
}

.blog_latest_more {
  margin-top: -10px !important;
}

.mw-thumb::after {
  content:"Market Watch";
}


.wp-block-latest-posts__post-title {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
}

.member_hub_top_excerpt a{
 color: white;
}

.wp-block-latest-posts__featured-image img {
    contain-intrinsic-size: 900px;
}
